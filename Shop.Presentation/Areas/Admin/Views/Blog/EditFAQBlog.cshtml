@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Shop.Domain.Entities.Blog;
@model FAQBlog
@{
    ViewData["Title"] = "EditFAQBlog";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="basic-elements">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="card-title-wrap bar-warning">
                        <div class="card-title">
                            ویرایش سوال متداول
                            <a href="~/Admin/Blog/IndexFAQsBlog" class="btn btn-primary btn_left_side">بازگشت &nbsp;<i class="fa fa-arrow-left"></i></a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="form">
                            <div class="form-body">
                                <div class="row">

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">سوال</label>
                                            <input type="hidden" id="FAQId" value="@Model.Id" />
                                            <input type="text" id="Question" class="form-control" value="@Model.Question" placeholder="سوال متداول را وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">پاسخ</label>
                                            <input type="text" id="Answer" class="form-control" value="@Model.Answer" placeholder="پاسخ را وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">پست/مقاله مرتبط</label>
                                            <select class="form-control" name="BlogEntity" id="BlogEntity" asp-items="@ViewBag.Blogs">
                                                @if (@Model.BlogEntity != null)
                                                {
                                                    <option selected="selected" value="@Model.BlogEntity.Id">
                                                        @Model.BlogEntity.Title
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option selected="selected">
                                                        انتخاب پست/مقاله مرتبط سوال متداول
                                                    </option>
                                                }
                                            </select>
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <br />
                                            <a onclick="EditFAQBlog()" class="btn btn-warning col-md-12"><i class="fa fa-edit"></i>&nbsp; ویرایش سوال متداول</a>
                                        </fieldset>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts
    {
    <link href="~/Sweetalert/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert/sweetalert2.min.js"></script>
    <script>
        function EditFAQBlog() {
            swal.fire({
                title: 'ویرایش سوال متداول',
                text: "آیا میخواهید سوال متداول را ویرایش نمائید؟",
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، ویرایش شود',
                cancelButtonText: 'خیر'
            }).then((result) => {
                if (result.value) {
                    var FAQId = $("#FAQId").val();
                    var Question = $("#Question").val();
                    var Answer = $("#Answer").val();
                    var BlogEntityId = $('#BlogEntity').find('option:selected').val();
                    
                    var data = new FormData();
                    // Get values from textbox's and etc
                    data.append("Id", FAQId);
                    data.append("Question", Question);
                    data.append("Answer", Answer);
                    data.append("BlogId", BlogEntityId);

                    $.ajax({
                        contentType: false,
                        processData: false,
                        type: "POST",
                        url: "EditFAQBlog",
                        data: data,
                        success: function (data) {
                            if (data.isSuccess == true) {
                                swal.fire(
                                    'موفق!',
                                    data.message,
                                    'success'
                                ).then(function (isConfirm) {
                                    location.reload();
                                });
                            }
                            else {
                                swal.fire(
                                    'هشدار!',
                                    data.message,
                                    'warning'
                                );
                            }
                        },
                        error: function (request, status, error) {
                            swal.fire(
                                'هشدار!',
                                request.responseText,
                                'warning'
                            );
                        }
                    });
                }
            })
        }
    </script>
}