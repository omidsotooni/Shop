@using Shop.Application.Dtos.BlogDtos;
@addTagHelper *, LazZiya.TagHelpers
@model FAQForAdminDto
@{
    ViewData["Title"] = "IndexFAQsBlog";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-fluid">
        <section id="configuration">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title-wrap bar-success">
                                <h4 class="card-title">سوالات متداول</h4>
                                <span class="card-text">لیست سوالات متداول</span>
                                <a href="~/Admin/Blog/AddNewFAQ" class="btn btn-success btn_left_side"><i class="fa fa-plus"></i>&nbsp;افزودن سوال متداول جدید</a>
                            </div>
                        </div>
                        <div class="card-body collapse show">
                            <div class="card-block card-dashboard">
                                <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper container-fluid dt-bootstrap4">
                                    <div class="col-sm-12">
                                        <table class="table table-striped table-bordered zero-configuration dataTable" id="DataTables_Table_0" role="grid" aria-describedby="DataTables_Table_0_info">
                                            <thead>
                                                <tr role="row">
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="سوال: activate to sort column descending" style="width: 222px;">سوال</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="پاسخ: activate to sort column descending" style="width: 222px;">پاسخ</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="پست/مقاله مرتبط: activate to sort column descending" style="width: 222px;">پست/مقاله مرتبط</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label=": activate to sort column descending" style="width: 222px;">عملیات</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.FAQsBlog)
                                                {
                                                    <tr role="row" class="odd">
                                                        <td class="sorting_1">@item.Question</td>
                                                        <td class="sorting_1">@item.Answer</td>
                                                        <td class="sorting_1"><a href="~/Blog/@item.Slug" target="_blank">@item.Title</a></td>

                                                        <td>
                                                            <a href="~/Admin/Blog/EditFAQBlog?Id=@item.Id" class="btn btn-warning"><i class="fa fa-edit"></i> &nbsp;ویرایش</a>
                                                            <button class="btn btn-danger" onclick="DeleteFAQBlog('@item.Id')"><i class="fa fa-trash-o"></i> &nbsp;حذف</button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <paging total-records="Model.RowCount"
                                            page-no="Model.CurrentPage"
                                            page-size="Model.PageSize"
                                            show-prev-next="true"
                                            show-total-pages="true"
                                            show-total-records="true"
                                            show-page-size-nav="true"
                                            show-first-numbered-page="true"
                                            show-last-numbered-page="true"
                                            gap-size="2"
                                            page-size-dropdown-items="10-20-30-50-100-500"
                                            max-displayed-pages="3"
                                            query-string-key-page-no="Page"
                                            query-string-key-page-size="PageSize"
                                            query-string-value="@@(Request.QueryString.Value)"
                                            page-size-nav-block-size="10"
                                            page-size-nav-max-items="3"
                                            page-size-nav-on-change="get"
                                            page-size-nav-form-method="this.form.submit();"
                                            class="row"
                                            class-paging-control-div="col"
                                            class-info-div="col"
                                            class-page-size-div="col"
                                            class-paging-control="pagination"
                                            class-active-page="active"
                                            class-disabled-jumping-button="active"
                                            class-total-pages="badge badge-secondary"
                                            class-total-records="badge badge-info"
                                            text-page-size="موارد در هر برگه:"
                                            text-total-pages="برگه"
                                            text-total-records="محصول"
                                            text-first="&laquo;"
                                            text-last="&raquo;"
                                            text-previous="&lsaquo;"
                                            text-next="&rsaquo;"
                                            sr-text-first="نسخین"
                                            sr-text-last="آخرین"
                                            sr-text-previous="پیشین"
                                            sr-text-next="پسین">
                                    </paging>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>



@section Scripts
    {

    <link href="~/Sweetalert/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert/sweetalert2.min.js"></script>

    <script>
        function DeleteFAQBlog(Id) {
            swal.fire({
                title: 'حذف سوال متداول',
                text: "کاربر گرامی از حذف سوال متداول مطمئن هستید؟",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#7cacbe',
                confirmButtonText: 'بله ، سوال متداول حذف شود',
                cancelButtonText: 'خیر'
            }).then((result) => {
                if (result.value) {
                    var postData = {
                        'faqId': Id,
                    };

                    $.ajax({
                        contentType: 'application/x-www-form-urlencoded',
                        dataType: 'json',
                        type: "POST",
                        url: "DeleteFAQBlog",
                        data: postData,
                        success: function (data) {
                            if (data.isSuccess == true) {
                                swal.fire(
                                    'موفق!',
                                    data.message,
                                    'success'
                                ).then(function (isConfirm) {
                                    location.reload();
                                });
                            }
                            else {

                                swal.fire(
                                    'هشدار!',
                                    data.message,
                                    'warning'
                                );
                            }
                        },
                        error: function (request, status, error) {
                            alert(request.responseText);
                        }
                    });
                }
            })
        }
    </script>
}