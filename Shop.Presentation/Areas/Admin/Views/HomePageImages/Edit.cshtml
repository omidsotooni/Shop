@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@using Shop.Application.Services.HomePage.Commands.HomePageImagesService;
@using Shop.Domain.Entities.HomePages;
@model RequestEditHomePageImagesDto;
@{
    ViewData["Title"] = "ویرایش تصویر";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="basic-elements">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="card-title-wrap bar-success">
                        <div class="card-title">
                            ویرایش تصویر
                            <a href="~/Admin/HomePageImages/Index" class="btn btn-primary btn_left_side">بازگشت &nbsp;<i class="fa fa-arrow-left"></i></a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="form">
                            <div class="form-body">
                                <div class="row">

                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <input type="hidden" id="HomePageImaesId" value="@Model.Id" />
                                            <label for="basicInput">عنوان تصویر</label>
                                            <input type="text" class="form-control" id="AltName" value="@Model.AltName">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">آدرس محصول وابسته</label>
                                            <input type="text" class="form-control" id="Link" value="@Model.Link">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">در صفحه اصلی سایت نمایش داده شود؟ </label>
                                            <input type="checkbox" class="form-control" id="IsActive" name="@Model.IsActive" checked="@Model.IsActive">
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">موقعیت نمایش تصویر در سایت</label>
                                            <select class="form-control" id="ImageLocation" name="imageLocation" asp-items="@Html.GetEnumSelectList<ImageLocation>()">
                                                @if (@Model.ImageLocation != null)
                                                {
                                                    <option selected="selected" value="@Model.ImageLocation">
                                                        @Model.ImageLocation
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option selected="selected">
                                                        دسته بندی را انتخاب کنید
                                                    </option>
                                                }
                                            </select>
                                            <p><small class="text-muted">مکان تصویر در صفحه اصلی را تعیین کنید</small></p>
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-8 col-lg-6 col-md-12 mb-1">
                                        <figure class="text-center">
                                            <a target="_blank" href="~/@Model.Src">
                                                <img width="400" id="Src" height="200" class="img-thumbnail img-fluid" src="~/@Model.Src">
                                            </a>
                                        </figure>
                                    </div>

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">افزودن تصویر جدید </label>
                                            <input type="file" class="form-control" accept="image/*" id="Images">
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <br />
                                            <a onclick="EditPicture()" class="btn btn-warning col-md-12"><i class="fa fa-edit"></i>&nbsp; ویرایش تصویر</a>
                                        </fieldset>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts
    {
    <link href="~/Sweetalert/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert/sweetalert2.min.js"></script>
    <script>

        function EditPicture() {
            swal.fire({
                title: 'ویرایش تصویر',
                text: "تصویر ویرایش شود؟",
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، ویرایش شود',
                cancelButtonText: 'خیر'
            }).then((result) => {
                if (result.value) {
                    var HomePageImaesId = $("#HomePageImaesId").val();
                    var Link = $("#Link").val();
                    var AltName = $("#AltName").val();
                    var ImageLocation = $("#ImageLocation").val();
                    var IsActive = $('#IsActive').is(':checked');
                    var Src = $("#Src").val();

                    var data = new FormData();
                    data.append("Link", Link);
                    data.append("Id", HomePageImaesId);
                    data.append("AltName", AltName);
                    data.append("Src", Src);
                    data.append("IsActive", IsActive);
                    data.append("ImageLocation", ImageLocation);
                    //Receiving the photos selected by the user and placing the photos in the data variable
                    var productImages = document.getElementById("Images");
                    if (productImages.files.length > 0) {
                        for (var i = 0; i < productImages.files.length; i++) {
                            data.append('Images-' + i, productImages.files[i]);
                        }
                    }

                    $.ajax({
                        contentType: false,
                        processData: false,
                        type: "POST",
                        url: "Edit",
                        data: data,
                        success: function (data) {
                            if (data.isSuccess == true) {
                                debugger;
                                swal.fire(
                                    'موفق!',
                                    data.message,
                                    'success'
                                ).then(function (isConfirm) {
                                    location.reload();
                                });
                            }
                            else {
                                swal.fire(
                                    'هشدار!',
                                    data.message,
                                    'warning'
                                );
                            }
                        },
                        error: function (request, status, error) {
                            swal.fire(
                                'هشدار!',
                                request.responseText,
                                'warning'
                            );
                        }
                    });
                }
            })
        }

    </script>
}
