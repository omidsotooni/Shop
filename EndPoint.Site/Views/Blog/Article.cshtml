@using Shop.Infrastructure.Dtos.BlogDtos;
@model DetailBlogDto
@{
    ViewData["Title"] = "مقالات فروشگاه اینترنتی";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string host = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

@section Head {
    <!-- canonical !-->
    <link rel="canonical" href="@Model.Canonical == null ? @(host + $"/Blog/{Model.Slug}/") : @Model.Canonical" />
    <!-- NewsArticle Schema ld+json !-->
    <script defer type="application/ld+json">
        {
          "@@context" : "http://schema.org",
           "@@type" : "NewsArticle",
           "provider" : {
                          "@@type" : "Organization",
                          "name"   : "فروشگاه اینترنتی",
                          "alternateName": "Iranian online shop",
                          "description": "Iranian online shop.",
                          "url": "https://omidsotooni.github.io/",
                          "logo": "~/UserTemplate/assets/images/logo.png",
                          "contactPoint": [
                              {
                                  "@@type": "ContactPoint", "telephone": "+989011234567", "contactType": "education", "areaServed": "IR", "availableLanguage": "Persian"
                              }
                              ,
                              {
                                  "@@type": "ContactPoint", "telephone": "+989011234567", "contactType": "technical support", "areaServed": "IR", "availableLanguage": "Persian"
                              }
                          ],
                          "sameAs": [
                              "https://omidsotooni.github.io/",
                              "https://omidsotooni.github.io/"
                          ] },
          "datePublished" : "@Model.DatePublished.ToString("s")",
          "image" : "@(Model.Title == null ? "blog image" : Model.Title)",
          "genre" : "@Html.Raw(Model.CategoryText)",
          "headline" : "@Html.Raw(Model.Title)",
          "author":[ {
              "@@type": "Person",
              "name": "@(Model.UserName == null || Model.UserName == "" ? "Omid Sotooni" : Model.UserName)",
              "url": "@(Model.AuthorUrl == null || Model.AuthorUrl == "" ? "https://omidsotooni.github.io/" : Model.AuthorUrl)"
                }]
        }
    </script>
    <!-- FAQ Schema ld+json !-->
    <script type="application/ld+json" defer>
        {
        @if (@Model.FAQBlogs.Count() > 0)
        {
            <text>
                        "@@context": "https://schema.org",
                        "@@type": "FAQPage",
                        "mainEntity": [
            </text>
            @foreach (var item in @Model.FAQBlogs)
            {
                <text>
                            {
                                "@@type": "Question",
                                "name": "@item.Question",
                                "acceptedAnswer": {
                                    "@@type": "Answer",
                                    "text": "@item.Answer"
                                }
                            }
                </text>
                @if (@Model.FAQBlogs.LastOrDefault()?.Id != item.Id)
                {
                    <text>
                                    ,
                    </text>
                }
            }
            <text>
                            ]
            </text>
        }
        }
    </script>
}

<article class="container" itemscope itemtype="http://schema.org/BlogPosting" itemprop="blogPost">
    <header>
        <h1 itemprop="name headline"><a href="@(host + $"/Blog/{Model.Slug}/")" rel="canonical" itemprop="url">@Model.Title</a></h1>
        <time datetime="@Model.DatePublished.ToString("s")" itemprop="datePublished">تاریخ انتشار @Model.DatePublished.ToString("MMM d, yyyy")</time>
    </header>
    <div itemprop="articleBody mainEntityOfPage" cdnify>
        <div>
            <p>@Model.Description</p>
            <img src="~/@Model.PictureSrc" class="img-fluid" />
        </div>
        @Model.Content
    </div>
    <footer>
        @if (@Model.FAQBlogs.Count() > 0)
        {
            <div class="row">
                <section class="container my-5" id="maincontent">
                    <h6 class="faq-heading">سوالات متداول <small>برای مشاهده روی سوالات کلیک نمائید.</small> </h6>
                    <section id="accordion">
                        @foreach (var item in @Model.FAQBlogs)
                        {
                            <a class="py-3 d-block h-100 w-100 position-relative z-index-1 pr-1 text-secondary border-top" aria-controls="maincontent" aria-expanded="false" data-toggle="collapse" href="#faq-@item.Id" role="button">
                                <div class="position-relative h4 m-0 pr-3">
                                    @item.Question
                                    <div class="position-absolute top-0 right-0 h-100 d-flex align-items-center">
                                        <i class="fa fa-plus"></i>
                                    </div>
                                </div>
                            </a>
                            <div class="collapse" id="faq-@item.Id" style="">
                                <div class="card card-body border-0 p-0">
                                    <p>@item.Answer</p>
                                </div>
                            </div>
                        }
                    </section>
                </section>
            </div>
        }
        @if (Model.Tags.Any())
        {
            <svg width="24" height="24" aria-hidden="true" role="img" aria-labelledby="_tags-@Model.Title" focusable="false" viewBox="0 0 24 24">
                <title id="_tags-@Model.Title">کلمات کلیدی</title>
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z" fill="gray"></path>
                <path d="M0 0h24v24H0z" fill="none"></path>
            </svg>
            <text>کلمات کلیدی: </text>
            <br />
            <div class="row">
                @foreach (string tag in Model.Tags.Split(","))
                {
                    <div class="col-2 mt-2">
                        <a href="~/Blog?SearchKey=@tag">
                            <div class="bg-white text-center fs-small tag rounded">@tag &ensp;</div>
                        </a>
                    </div>
                }
            </div>
        }
        <br />
        <div>
            <ul class="next_prev clr">
                <li class="previous">
                    <a href="@(host + $"/Blog/{Model.Slug}")" target="_blank" rel="prev" title="مقاله قبلی: @Model.Title">
                        <i class="fa fa-angle-right"></i><h4><small>مقاله قبلی</small><br /> @Model.Title</h4>
                    </a>
                </li>
                <li class="next">
                    <a href="@(host + $"/Blog/{Model.Slug}")" target="_blank" rel="next" title="مقاله بعدی: @Model.Title">
                        <h4><small>مقاله بعدی</small><br /> @Model.Title</h4><i class="fa fa-angle-left"></i>
                    </a>
                </li>
            </ul>
        </div>
        <br />
        <a href="@(host + $"/Blog/{Model.Slug}/#comments")" itemprop="discussionUrl" title="برو به بخش نظرات">
            @*<span itemprop="commentCount">@Model.Comments.Count</span> @(Model.Comments.Count == 1 ? "comment" : "comments")*@
            برو به بخش نظرات
        </a>

        <meta itemprop="author" content="@Model.UserName" />
        <meta itemprop="dateModified" content="@Model.LastModified.Value.ToString("s")" />
        <meta itemprop="mainEntityOfPage" content="@(host + $"/Blog/{Model.Slug}/")" />
    </footer>
</article>