@addTagHelper *, LazZiya.TagHelpers
@using Shop.Common;
@using Shop.Infrastructure.Dtos.BlogDtos;
@model ResultBlogForSiteListDto;
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int pageNumber = 1;
    int pageSize = 20;
    int.TryParse(Context.Request.Query["Page"], out pageNumber);
    int.TryParse(Context.Request.Query["PageSize"], out pageSize);
}
@section Head {
    <!-- NewsArticle Schema ld+json !-->
<script defer type="application/ld+json">
    {
      "@@context" : "http://schema.org",
      "@@type" : "NewsArticle",
      "provider" :
                {
                    "@@type" : "Organization",
                    "name"   : "فروشگاه اینترنتی",
                    "alternateName": "Iranian online shop",
                    "description": "Iranian online shop.",
                    "url": "https://omidsotooni.github.io/",
                    "logo": "UserTemplate/assets/images/logo.png",
                    "contactPoint": [
                                  {
                                      "@@type": "ContactPoint", "telephone": "+989011234567", "contactType": "education", "areaServed": "IR", "availableLanguage": "Persian"
                                  }
                                  ,
                                  {
                                      "@@type": "ContactPoint", "telephone": "+989011234567", "contactType": "technical support", "areaServed": "IR", "availableLanguage": "Persian"
                                  }
                      ],
                          "sameAs": [
                                  "https://omidsotooni.github.io/",
                                  "https://omidsotooni.github.io/"
                      ]
                },        
        "headline" : [
    @foreach (var item in Model.Blogs)
    {
        <text>
            "@Html.Raw(item.Title)"
        </text>
        @if (Model.Blogs.LastOrDefault()?.Id != item.Id)
        {
            <text>
                ,
            </text>
        }
    }
        ],
        "genre" : [
    @foreach (var item in Model.Blogs)
    {
        <text>
            @{
                var url = @item.CategoryText == null ? "Academy online shop" : @item.CategoryText;
            }
            "@Html.Raw(url)"
        </text>
        @if (Model.Blogs.LastOrDefault()?.Id != item.Id)
        {
            <text>
                ,
            </text>
        }
    }
        ]
        ,"author":[ {
          "@@type": "Person",
                "name": "@(Model.Blogs.First().UserName == null || Model.Blogs.First().UserName == "" ? "Omid Sotooni" : Model.Blogs.First().UserName)",
                "url":  "@(Model.Blogs.First().AuthorUrl == null || Model.Blogs.First().AuthorUrl == "" ? "https://omidsotooni.github.io/" : Model.Blogs.First().AuthorUrl)"
            }]

    }
</script>
}

<div class="col-lg-12 col-md-12 col-xs-12 pl">
    <div class="shop-archive-content mt-3 d-block">
        <div class="archive-header">
            <h2 class="archive-header-title">مقالات فروشگاه ( @Model.RowCount پست )</h2>
        </div>
        @if (Model.Blogs.Any())
        {
            <div class="product-items">
                <div class="tab-content" id="articles">
                    <div class="row">
                        @foreach (var item in Model.Blogs)
                        {
                            <div class="col-lg-4 col-md-4 col-xs-12 col-xs-12 order-1 d-block mb-3">
                                <section class="product-box product product-type-simple" style="padding:15px 15px 15px;">
                                    <span style="float:right;">
                                        <i class="fa fa-list-alt"></i> دسته:
                                        <a title="@item.CategoryText" href="#">@item.CategoryText</a>
                                    </span>
                                    <span style="float:left;"> <i class="fa fa-eye"></i> بازدید: @item.ViewCount </span>
                                    <div class="thumb">
                                        <a title="@item.Title" href="~/Blog/@item.Slug" class="d-block">
                                            <img src="~/@item.PictureSrc">
                                        </a>
                                    </div>
                                    <div class="title">
                                        <a title="@item.Title" href="~/Blog/@item.Slug">@item.Title</a>
                                    </div>
                                    <p>
                                        @item.Description.Substring(0, 100)
                                    </p>
                                    <div>
                                        <span style="float:right;">
                                            <i class="fa fa-clock-o"></i>
                                            @{
                                                string InsertDate = Utility.KhorshidiJustDate(item.InsertDate);
                                            }
                                            تاریخ انتشار: @InsertDate
                                        </span>
                                        <span style="float:left;"> <i class="fa fa-user"></i> نویسنده: <a title="@item.UserName" href="#">@item.UserName</a> </span>
                                    </div>
                                </section>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="pagination-product">
                <nav aria-label="Page navigation example">
                    <div class="text-center">
                        <paging total-records="@Model.RowCount"
                            page-no="@pageNumber == 0 ? 1 : pageNumber"
                            page-size="@pageSize == 0 ? 20: pageSize"
                            show-prev-next="true"
                            show-total-pages="true"
                            show-total-records="true"
                            show-page-size-nav="true"
                                show-first-numbered-page="true"
                                show-last-numbered-page="true"
                                gap-size="2"
                            max-displayed-pages="4"
                            query-string-key-page-no="Page"
                            query-string-key-page-size="PageSize"
                                query-string-value="@@(Request.QueryString.Value)"
                            page-size-dropdown-items="10-20-30-50-100-500"
                                page-size-nav-block-size="10"
                                page-size-nav-max-items="4"
                                page-size-nav-on-change="get"
                                page-size-nav-form-method="this.form.submit();"
                            class="row"
                            class-paging-control-div="col"
                            class-info-div="col"
                            class-page-size-div="col"
                            class-paging-control="pagination"
                            class-active-page="active"
                            class-disabled-jumping-button="active"
                            class-total-pages="badge badge-primary"
                            class-total-records="badge badge-info"
                            text-page-size="موارد در هر برگه:"
                            text-total-pages="برگه"
                            text-total-records="مقاله"
                            text-first="&laquo;"
                            text-last="&raquo;"
                            text-previous="&lsaquo;"
                            text-next="&rsaquo;"
                            sr-text-first="نخستین"
                            sr-text-last="آخرین"
                            sr-text-previous="پیشین"
                            sr-text-next="پسین">
                        </paging>
                    </div>
                </nav>
            </div>
        }
        else
        {
            <div class="product-items">
                <div class="tab-content" id="articles">
                    <p>
                        متاسفانه مقاله ای پیدا نشد!
                    </p>
                </div>
            </div>

        }
    </div>
</div>