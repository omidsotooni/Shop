@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "AddNewFAQ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="basic-elements">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="card-title-wrap bar-success">
                        <h4 class="card-title mb-0">اضافه کردن سوال متدوال جدید</h4>
                    </div>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="form">
                            <div class="form-body">
                                <div class="row">                                   

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">سوال</label>
                                            <input type="text" id="Question" class="form-control" placeholder="سوال متداول را وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">پاسخ</label>
                                            <input type="text" id="Answer" class="form-control" placeholder="پاسخ را وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">پست/مقاله مرتبط</label>
                                            <select class="form-control" name="Blogs" id="Blogs" asp-items="@ViewBag.Blogs"></select>
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <br />
                                            <a onclick="AddNewFAQ()" class="btn btn-success col-md-12"><i class="fa fa-plus"></i> &nbsp;اضافه کردن سوال متدوال</a>
                                        </fieldset>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts
    {
    <link href="~/Sweetalert/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert/sweetalert2.min.js"></script>

    <script>
        function AddNewFAQ() {
            swal.fire({
                title: 'سوال متداول جدید',
                text: "آیا میخواهید سوال متداول اضافه شود؟",
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، سوال متداول اضافه شود',
                cancelButtonText: 'خیر'
            }).then((result) => {
                if (result.value) {
                    var Question = $("#Question").val();
                    var Answer = $("#Answer").val();
                    var BlogId = $('#Blogs').find('option:selected').val();

                    var postData = {
                        'BlogId': BlogId,
                        'Question': Question,
                        'Answer': Answer,

                    };
                    $.ajax({
                        contentType: 'application/x-www-form-urlencoded',
                        dataType: 'json',
                        type: "POST",
                        url: "AddNewFAQ",
                        data: postData,
                        success: function (data) {
                            if (data.isSuccess == true) {
                                swal.fire(
                                    'موفق!',
                                    data.message,
                                    'success'
                                ).then(function (isConfirm) {
                                    location.reload();
                                });
                            }
                            else {
                                swal.fire(
                                    'هشدار!',
                                    data.message,
                                    'warning'
                                );
                            }
                        },
                        error: function (request, status, error) {
                            swal.fire(
                                'هشدار!',
                                request.responseText,
                                'warning'
                            );
                        }
                    });
                }
            })
        }
    </script>
}
