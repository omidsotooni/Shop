@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Shop.Common;
@using Shop.Infrastructure.Dtos.BlogDtos;
@using static Shop.Common.Utility;
@model EditBlogDto
@{
    ViewData["Title"] = "ویرایش مطلب";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="basic-elements">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="card-title-wrap bar-warning">
                        <div class="card-title">
                            ویرایش مطلب
                            <a href="~/Admin/Blog/Index" class="btn btn-primary btn_left_side">بازگشت &nbsp;<i class="fa fa-arrow-left"></i></a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="form">
                            <div class="form-body">
                                <div class="row">

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">عنوان مطلب</label>
                                            <input type="hidden" id="BlogId" value="@Model.Id" />
                                            <input type="hidden" id="UserId" value="@ViewBag.UserId" />
                                            <input type="text" id="Title" class="form-control" value="@Model.Title" placeholder="عنوان مطلب را وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">آدرس مطلب</label>
                                            <input type="text" id="Slug" class="form-control" value="@Model.Slug" placeholder="آدرس مطلب را ترجیحا انگلیسی وارد نمائید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">توضیح کوتاه برای مطلب</label>
                                            <textarea id="Description" class="form-control" placeholder="یک توضیح کوتاه حدود 160 کاراکتر وارد نمائید" minlength="20" maxlength="200" rows="2">
                                                @Model.Description
                                            </textarea>
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">تک های مطلب(لیستی از کلمات کلیدی جدا شده با کاما بسازید)</label>
                                            <input type="text" id="Tags" class="form-control" value="@Model.Tags" placeholder="تگ های مطلب را وارد نمائید، لیستی از کلمات کلیدی جدا شده با کاما بسازید مانند: لپ تاب، کامپیوتر، موبایل">
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">دسته بندی مطلب </label>
                                            <select class="form-control" name="BlogCategories" id="BlogCategories" asp-items="@ViewBag.BlogCategories">
                                                @if (@Model?.BlogCategoryId != null)
                                                {
                                                    <option selected="selected" value="@Model.BlogCategoryId">
                                                        @Model.CategoryText
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option selected="selected">
                                                        انتخاب وضعیت مطلب
                                                    </option>
                                                }
                                            </select>
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">وضعیت مطلب </label>
                                            <select class="form-control" name="BlogStatus" id="BlogStatus" asp-items="@Html.GetEnumSelectList<BlogStatus>()">
                                                @if (@Model?.BlogStatus != null)
                                                {
                                                    string status = EnumHelpers<BlogStatus>.GetDisplayValue(@Model.BlogStatus);
                                                    <option selected="selected" value="@Model.BlogStatus.ToString()">
                                                        @status                                                        
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option selected="selected">
                                                        انتخاب وضعیت مطلب
                                                    </option>
                                                }
                                            </select>
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">زبان</label>
                                            <select class="form-control" name="Language" id="Language" asp-items="@Html.GetEnumSelectList<Languages>()">
                                                @if (@Model?.LanguageId != null)
                                                {
                                                    <option selected="selected" value="@Model.LanguageId">
                                                        @Model.LanguageTitle
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option selected="selected">
                                                        انتخاب زبان مطلب
                                                    </option>
                                                }
                                                <p><small class="text-muted">پیش فرض بصورت فارسی ذخیره میشود.</small></p>
                                            </select>
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">افزدون تصویر جدید</label>
                                            <input type="file" class="form-control" accept="image/*" id="NewBlogImages">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-4 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">زمان مطالعه</label>
                                            <input type="number" class="form-control" id="ReadingTime" value="@Model?.ReadingTime">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-2 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">IsFollowed؟</label>
                                            <input type="checkbox" class="form-control" id="IsFollowed" value="@Model?.IsFollowed" checked="@Model?.IsFollowed">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-2 col-lg-6 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">IsIndexed؟</label>
                                            <input type="checkbox" class="form-control" id="IsIndexed" value="@Model?.IsIndexed" checked="@Model?.IsIndexed">
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">آدرس کنونیکال</label>
                                            <input type="text" class="form-control" id="Canonical" value="@Model?.Canonical" placeholder="آدرس کنونیکال را بدون دامنه وارد نمائید مانند: /blog/ArticleAddress در صورت عدم نیاز خالی بگذارید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">آدرس ویدئو</label>
                                            <input type="text" class="form-control" id="VideoUrl" value="@Model?.VideoUrl" placeholder="آدرس ویدئو را وارد نمائید مانند: https://www.youtube.com/watch?v=address در صورت عدم نیاز خالی بگذارید">
                                        </fieldset>
                                    </div>
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">آدرس ریدایرکت</label>
                                            <input type="text" class="form-control" id="UrlRedirect" value="@Model?.UrlRedirect" placeholder="آدرس ریدایرکت را بدون دامنه نمائید مانند: /blog/RedirectToArticleAddress در صورت عدم نیاز خالی بگذارید">
                                        </fieldset>
                                    </div>

                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <label for="basicInput">محتوای اصلی مطلب</label>
                                            <textarea id="Content" class="form-control" placeholder="محتوای اصلی مطلب را وارد نمائید." rows="5">@Model?.Content</textarea>
                                        </fieldset>
                                    </div>
                                    @if (Model.FAQBlogs.Any())
                                    {
                                        <hr /><hr />
                                        <p> سوالات متداول این مطلب برای ویرایش سوالات متداول به بخش سوالات متداول بروید. 
                                            <a href="~/Admin/Blog/FAQs">
                                                سوالات متداول مطالب
                                            </a>
                                         </p>
                                        <table id="tbl_FAQs" class="col-md-12 table table-bordered table-hover table-condensed table-responsive">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        سوال
                                                    </th>
                                                    <th>
                                                        پاسخ
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.FAQBlogs)
                                                {
                                                    <tr role="row">
                                                        <td>@item.Question</td>
                                                        <td>@item.Answer</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>                                        
                                        <br class="clear" />
                                    }
                                    <div class="col-xl-12 col-lg-12 col-md-12 mb-1">
                                        <fieldset class="form-group">
                                            <br />
                                            <a onclick="EditBlog()" class="btn btn-warning col-md-12"><i class="fa fa-edit"></i>&nbsp; ویرایش مطلب</a>
                                        </fieldset>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts
    {
    <link href="~/Sweetalert/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert/sweetalert2.min.js"></script>
    <script>
        function EditBlog() {
            swal.fire({
                title: 'ویرایش مطلب',
                text: "آیا میخواهید مطلب را ویرایش نمائید؟",
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، ویرایش شود',
                cancelButtonText: 'خیر'
            }).then((result) => {
                if (result.value) {
                    var Id = $("#BlogId").val();
                    var Content = $("#Content").val();
                    var UrlRedirect = $("#UrlRedirect").val();
                    var VideoUrl = $("#VideoUrl").val();
                    var Canonical = $("#Canonical").val();
                    var IsIndexed = $('#IsIndexed').is(':checked');
                    var IsFollowed = $('#IsFollowed').is(':checked');
                    var ReadingTime = $("#ReadingTime").val();
                    var LanguageId = $('#Language').find('option:selected').val();
                    var BlogStatus = $('#BlogStatus').find('option:selected').val();
                    var BlogCategoryId = $('#BlogCategories').find('option:selected').val();
                    var Description = $("#Description").val();
                    var Slug = $("#Slug").val();
                    var Title = $("#Title").val();
                    var UserId = $("#UserId").val();
                    var Tags = $("#Tags").val();

                    var data = new FormData();
                    // Get values from textbox's and etc
                    data.append("Id", Id);
                    data.append("Content", Content);
                    data.append("UrlRedirect", UrlRedirect);
                    data.append("VideoUrl", VideoUrl);
                    data.append("Canonical", Canonical);
                    data.append("IsIndexed", IsIndexed);
                    data.append("IsFollowed", IsFollowed);
                    data.append("ReadingTime", ReadingTime);
                    data.append("LanguageId", LanguageId);
                    data.append("BlogStatus", BlogStatus);
                    data.append("BlogCategoryId", BlogCategoryId);
                    data.append("Description", Description);
                    data.append("Slug", Slug);
                    data.append("Title", Title);
                    data.append("UserId", UserId);
                    data.append("Tags", Tags);
                    //Receiving the photos selected by the user and placing the photos in the data variable
                    var productImages = document.getElementById("NewBlogImages");
                    if (productImages.files.length > 0) {
                        for (var i = 0; i < productImages.files.length; i++) {
                            data.append('Images-' + i, productImages.files[i]);
                        }
                    }

                    $.ajax({
                        contentType: false,
                        processData: false,
                        type: "POST",
                        url: "EditBlog",
                        data: data,
                        success: function (data) {
                            if (data.isSuccess == true) {
                                swal.fire(
                                    'موفق!',
                                    data.message,
                                    'success'
                                ).then(function (isConfirm) {
                                    location.reload();
                                });
                            }
                            else {
                                swal.fire(
                                    'هشدار!',
                                    data.message,
                                    'warning'
                                );
                            }
                        },
                        error: function (request, status, error) {
                            swal.fire(
                                'هشدار!',
                                request.responseText,
                                'warning'
                            );
                        }
                    });
                }
            })
        }
    </script>
}