                                    <li>
                                        <a href="~/Admin/Blog/Index" class="menu-item">لیست مطالب</a>
                                    </li>
                                    <li>
                                        <a href="~/Admin/Blog/AddNewBlog" class="menu-item">افزودن مطلب جدید *</a>
                                    </li>
                                    <li>
                                        <a href="~/Admin/Blog/IndexBlogCategories" class="menu-item">دسته بندی مطالب</a>
