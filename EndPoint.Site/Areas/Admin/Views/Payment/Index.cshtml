@addTagHelper *, LazZiya.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Shop.Application.Services.Fainances.Queries;
@using Shop.Common;
@using static Shop.Common.Utility;
@model PaymentsListForAdminDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-fluid">
        <section id="configuration">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title-wrap bar-success">
                                <h4 class="card-title">لیست فاکتورها</h4>
                                <span class="card-text">فاکتورهای فروشگاه اینترتی</span>
                            </div>
                        </div>
                        <div class="card-body collapse show">
                            <div class="card-block card-dashboard">
                                <div id="DataTables_Table_0_wrapper" class="dataTables_wrapper container-fluid dt-bootstrap4">
                                    <div class="row">
                                        <div class="col-sm-12 col-md-12">
                                            <form method="get" class="form-search">
                                                <fieldset class="form-group">
                                                    <input type="search" name="searchkey" class="header-search-input" placeholder="برای جستجو سریع کد فاکتور را وارد نمائید . . .">
                                                    <button class="btn btn-search action-btns" type="submit">
                                                        <i class="fa fa-search"></i>
                                                    </button>
                                                </fieldset>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="col-sm-12">
                                        <table class="table table-striped table-bordered zero-configuration dataTable" id="DataTables_Table_0" role="grid" aria-describedby="DataTables_Table_0_info">
                                            <thead>
                                                <tr role="row">
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="شماره فاکتور: activate to sort column descending" style="width: 222px;"> شماره فاکتور</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="مبلغ: activate to sort column descending" style="width: 222px;"> مبلغ</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="کاربر: activate to sort column descending" style="width: 222px;"> کاربر</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="وضعیت پرداخت activate to sort column descending" style="width: 222px;"> وضعیت پرداخت</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="تاریخ پرداخت: activate to sort column descending" style="width: 222px;"> تاریخ پرداخت</th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="کد مرجع: activate to sort column descending" style="width: 222px;">  کد مرجع </th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="شناسه پرداخت: activate to sort column descending" style="width: 222px;">  شناسه پرداخت </th>
                                                    <th class="sorting_asc" tabindex="0" aria-controls="DataTables_Table_0" rowspan="1" colspan="1" aria-sort="ascending" aria-label="  activate to sort column descending" style="width: 222px;">    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.PaymentForAdminDtos)
                                                {
                                                    <tr role="row" class="odd">
                                                        <td class="sorting_1">@item.Id</td>
                                                        <td>@item.Amount.ToString("n0")</td>
                                                        <td>@item.UserName</td>
                                                        <td>
                                                            @{
                                                                string Paid = item.IsPaid == true ? "پرداخت موفق" : "پرداخت ناموفق";
                                                            }
                                                            <text>@Paid</text>
                                                        </td>
                                                        <td>
                                                            @{
                                                                string DateOfPayment = "0000:00:00";
                                                                @if(item.PaymentDate != null)
                                                                {
                                                                    DateOfPayment = @Utility.KhorshidiDateNull(item.PaymentDate);
                                                                }
                                                                <text>@DateOfPayment</text>
                                                            }
                                                        </td>
                                                        <td>@item.RefId</td>
                                                        <td>@item.Authority</td>                                                        
                                                        <td>
                                                            <a class="btn btn-info">جزئیات کاربر</a>
                                                            <a class="btn btn-danger">مشاهده فاکتور </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <paging total-records="Model.RowCount"
                                            page-no="Model.CurrentPage"
                                            page-size="Model.PageSize"
                                            show-prev-next="true"
                                            show-total-pages="true"
                                            show-total-records="true"
                                            show-page-size-nav="true"
                                            show-first-numbered-page="true"
                                            show-last-numbered-page="true"
                                            gap-size="2"
                                            page-size-dropdown-items="10-20-30-50-100-500"
                                            max-displayed-pages="3"
                                            query-string-key-page-no="Page"
                                            query-string-key-page-size="PageSize"
                                            query-string-value="@@(Request.QueryString.Value)"
                                            page-size-nav-block-size="10"
                                            page-size-nav-max-items="3"
                                            page-size-nav-on-change="get"
                                            page-size-nav-form-method="this.form.submit();"
                                            class="row"
                                            class-paging-control-div="col"
                                            class-info-div="col"
                                            class-page-size-div="col"
                                            class-paging-control="pagination"
                                            class-active-page="active"
                                            class-disabled-jumping-button="active"
                                            class-total-pages="badge badge-secondary"
                                            class-total-records="badge badge-info"
                                            text-page-size="موارد در هر برگه:"
                                            text-total-pages="برگه"
                                            text-total-records="محصول"
                                            text-first="&laquo;"
                                            text-last="&raquo;"
                                            text-previous="&lsaquo;"
                                            text-next="&rsaquo;"
                                            sr-text-first="نسخین"
                                            sr-text-last="آخرین"
                                            sr-text-previous="پیشین"
                                            sr-text-next="پسین">
                                    </paging>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>